{
  "name": "@lit-pigeon/editor",
  "version": "0.1.1",
  "description": "Lit Web Components UI for the Pigeon email editor",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@lit-pigeon/core": "workspace:^",
    "@tiptap/core": "^2.10.0",
    "@tiptap/extension-bubble-menu": "^2.10.0",
    "@tiptap/extension-color": "^2.10.0",
    "@tiptap/extension-font-family": "^2.10.0",
    "@tiptap/extension-link": "^2.10.0",
    "@tiptap/extension-text-style": "^2.10.0",
    "@tiptap/extension-underline": "^2.10.0",
    "@tiptap/pm": "^2.10.0",
    "@tiptap/starter-kit": "^2.10.0",
    "lit": "^3.1.0"
  },
  "devDependencies": {
    "happy-dom": "^20.9.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^2.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/snxstudio/lit-pigeon.git",
    "directory": "packages/editor"
  },
  "license": "MIT"
}
