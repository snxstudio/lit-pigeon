{
  "name": "@lit-pigeon/core",
  "version": "0.3.1",
  "description": "Pure TypeScript engine for the Pigeon email editor",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "immer": "^10.1.0",
    "nanoid": "^5.0.0"
  },
  "devDependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/snxstudio/lit-pigeon.git",
    "directory": "packages/core"
  },
  "license": "MIT",
  "homepage": "https://github.com/snxstudio/lit-pigeon/tree/main/packages/core#readme",
  "bugs": "https://github.com/snxstudio/lit-pigeon/issues",
  "author": "Lit Pigeon Contributors",
  "keywords": [
    "email",
    "email-template",
    "email-editor",
    "mjml",
    "html-email",
    "lit",
    "web-components",
    "drag-and-drop",
    "no-code"
  ]
}
