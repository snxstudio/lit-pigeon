{
  "name": "@lit-pigeon/lint",
  "version": "0.1.4",
  "description": "Pre-flight QA for Lit Pigeon documents — alt text, contrast, link, merge-tag, spam-score, image-weight, and link-reachability checks.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@lit-pigeon/core": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/snxstudio/lit-pigeon.git",
    "directory": "packages/lint"
  },
  "license": "MIT",
  "homepage": "https://github.com/snxstudio/lit-pigeon/tree/main/packages/lint#readme",
  "bugs": "https://github.com/snxstudio/lit-pigeon/issues",
  "author": "Lit Pigeon Contributors",
  "keywords": [
    "email",
    "email-template",
    "email-editor",
    "mjml",
    "html-email",
    "lit",
    "web-components",
    "lint",
    "accessibility",
    "qa"
  ]
}
