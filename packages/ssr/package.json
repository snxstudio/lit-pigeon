{
  "name": "@lit-pigeon/ssr",
  "version": "0.1.5",
  "description": "Server-side rendering API for Lit Pigeon — render, parse, validate, and merge-tag-substitute documents from Node with zero DOM dependencies.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@lit-pigeon/core": "workspace:^",
    "@lit-pigeon/parser-mjml": "workspace:^",
    "@lit-pigeon/renderer-mjml": "workspace:^"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/snxstudio/lit-pigeon.git",
    "directory": "packages/ssr"
  },
  "license": "MIT",
  "homepage": "https://github.com/snxstudio/lit-pigeon/tree/main/packages/ssr#readme",
  "bugs": "https://github.com/snxstudio/lit-pigeon/issues",
  "author": "Lit Pigeon Contributors",
  "keywords": [
    "email",
    "email-template",
    "email-editor",
    "mjml",
    "html-email",
    "lit",
    "web-components",
    "ssr",
    "server-side-rendering"
  ]
}
