{
  "name": "@lit-pigeon/rest",
  "version": "0.1.4",
  "description": "Framework-agnostic Node REST adapter for Lit Pigeon — render, parse, and validate documents over HTTP.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "lit-pigeon-rest": "./dist/bin/lit-pigeon-rest.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@lit-pigeon/core": "workspace:^",
    "@lit-pigeon/lint": "workspace:^",
    "@lit-pigeon/ssr": "workspace:^"
  },
  "peerDependencies": {},
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/snxstudio/lit-pigeon.git",
    "directory": "packages/rest"
  },
  "license": "MIT"
}
