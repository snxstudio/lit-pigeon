{
  "name": "lit-pigeon",
  "private": true,
  "version": "0.0.0",
  "description": "Open-source, framework-agnostic drag-and-drop email editor",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint packages/ apps/ --ext .ts,.tsx",
    "format": "prettier --write \"packages/*/src/**/*.ts\" \"apps/*/src/**/*.ts\"",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build --filter=!@lit-pigeon/playground && changeset publish",
    "size": "size-limit",
    "size:why": "size-limit --why",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@size-limit/preset-small-lib": "12.1.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "size-limit": "12.1.0",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "packageManager": "pnpm@9.1.0",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "overrides": {
      "minimatch@<3.1.4": ">=3.1.4",
      "minimatch@>=9.0.0 <9.0.7": ">=9.0.7",
      "minimatch@>=10.0.0 <10.2.3": ">=10.2.3",
      "rollup@>=4.0.0 <4.59.0": ">=4.59.0",
      "@angular/core@>=21.0.0-next.0 <21.2.4": ">=21.2.4",
      "flatted@<=3.4.1": ">=3.4.2",
      "brace-expansion@<1.1.13": ">=1.1.13",
      "brace-expansion@>=2.0.0 <2.0.3": ">=2.0.3",
      "picomatch@<2.3.2": ">=2.3.2",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "postcss@<8.5.10": ">=8.5.10",
      "turbo@<=2.9.13": ">=2.9.14",
      "js-cookie@<=3.0.5": ">=3.0.7"
    }
  }
}
