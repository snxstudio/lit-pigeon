{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lit-pigeon.dev/ai-spec/1.0/document.schema.json",
  "title": "PigeonDocument",
  "description": "A Lit Pigeon email document — the canonical authoring target for AI tools that produce emails. Render with `documentToMjml(doc)` and then `mjml2html(mjml)` to get email-safe HTML.",
  "type": "object",
  "required": ["version", "metadata", "body"],
  "properties": {
    "version": { "const": "1.0", "description": "Document schema version. Must be the literal string \"1.0\"." },
    "metadata": { "$ref": "#/$defs/Metadata" },
    "body": { "$ref": "#/$defs/Body" }
  },
  "$defs": {
    "Metadata": {
      "type": "object",
      "required": ["name", "createdAt", "updatedAt"],
      "properties": {
        "name": { "type": "string", "description": "Human-readable title of the email (used in editor UI; not rendered into HTML)." },
        "previewText": { "type": "string", "description": "Preheader text shown in email-client inboxes. Keep under ~80 characters." },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Body": {
      "type": "object",
      "required": ["attributes", "rows"],
      "properties": {
        "attributes": {
          "type": "object",
          "required": ["width", "backgroundColor", "fontFamily", "contentAlignment"],
          "properties": {
            "width": { "type": "integer", "minimum": 300, "maximum": 800, "default": 600, "description": "Email canvas width in pixels. 600 is the de-facto email standard." },
            "backgroundColor": { "type": "string", "description": "Hex color of the canvas background." },
            "fontFamily": { "type": "string", "description": "CSS font-family stack. Use web-safe fonts for best email-client compatibility." },
            "contentAlignment": { "enum": ["center", "left"], "default": "center" }
          }
        },
        "rows": { "type": "array", "items": { "$ref": "#/$defs/Row" } }
      }
    },
    "Row": {
      "type": "object",
      "description": "A horizontal band of one or more columns. Rows stack vertically.",
      "required": ["id", "type", "attributes", "columns", "columnRatios", "locked"],
      "properties": {
        "id": { "type": "string", "description": "Stable, unique id. Use createBlock/createRow helpers OR generate a UUID-shaped string." },
        "type": { "const": "row" },
        "attributes": {
          "type": "object",
          "required": ["padding", "fullWidth"],
          "properties": {
            "backgroundColor": { "type": "string" },
            "backgroundImage": { "type": "string", "format": "uri" },
            "padding": { "$ref": "#/$defs/Spacing" },
            "fullWidth": { "type": "boolean", "default": false }
          }
        },
        "columns": { "type": "array", "minItems": 1, "maxItems": 4, "items": { "$ref": "#/$defs/Column" } },
        "columnRatios": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4,
          "items": { "type": "integer", "minimum": 1, "maximum": 12 },
          "description": "Relative widths summing to 12. E.g. [6,6] = two equal columns; [8,4] = 2/3 + 1/3; [4,4,4] = three equal."
        },
        "locked": { "type": "boolean", "default": false }
      }
    },
    "Column": {
      "type": "object",
      "required": ["id", "type", "attributes", "blocks"],
      "properties": {
        "id": { "type": "string" },
        "type": { "const": "column" },
        "attributes": {
          "type": "object",
          "required": ["padding", "verticalAlign"],
          "properties": {
            "backgroundColor": { "type": "string" },
            "padding": { "$ref": "#/$defs/Spacing" },
            "borderRadius": { "type": "integer", "minimum": 0 },
            "verticalAlign": { "enum": ["top", "middle", "bottom"], "default": "top" }
          }
        },
        "blocks": { "type": "array", "items": { "$ref": "#/$defs/Block" } }
      }
    },
    "Spacing": {
      "type": "object",
      "description": "Four-sided spacing in pixels.",
      "required": ["top", "right", "bottom", "left"],
      "properties": {
        "top":    { "type": "integer", "minimum": 0 },
        "right":  { "type": "integer", "minimum": 0 },
        "bottom": { "type": "integer", "minimum": 0 },
        "left":   { "type": "integer", "minimum": 0 }
      }
    },
    "Block": {
      "oneOf": [
        { "$ref": "#/$defs/TextBlock" },
        { "$ref": "#/$defs/ImageBlock" },
        { "$ref": "#/$defs/ButtonBlock" },
        { "$ref": "#/$defs/DividerBlock" },
        { "$ref": "#/$defs/SpacerBlock" },
        { "$ref": "#/$defs/SocialBlock" },
        { "$ref": "#/$defs/HtmlBlock" },
        { "$ref": "#/$defs/HeroBlock" },
        { "$ref": "#/$defs/NavBarBlock" }
      ]
    },
    "TextBlock": {
      "type": "object",
      "required": ["id", "type", "values"],
      "properties": {
        "id": { "type": "string" },
        "type": { "const": "text" },
        "values": {
          "type": "object",
          "required": ["content", "padding", "lineHeight", "textAlign"],
          "properties": {
            "content": { "type": "string", "description": "HTML string. Allowed tags: p, br, strong, em, s, u, code, a, h1-h3, ul, ol, li, blockquote, span. Merge tags written as `{{identifier}}` text are rendered as chips in the editor." },
            "padding": { "$ref": "#/$defs/Spacing" },
            "lineHeight": { "type": "string", "description": "CSS line-height (e.g. \"1.5\", \"24px\")." },
            "textAlign": { "enum": ["left", "center", "right"] }
          }
        }
      }
    },
    "ImageBlock": {
      "type": "object",
      "required": ["id", "type", "values"],
      "properties": {
        "id": { "type": "string" },
        "type": { "const": "image" },
        "values": {
          "type": "object",
          "required": ["src", "alt", "width", "padding", "alignment"],
          "properties": {
            "src": { "type": "string", "format": "uri" },
            "alt": { "type": "string", "description": "Required for accessibility. Empty string is permitted for decorative images." },
            "width": { "oneOf": [{ "type": "integer", "minimum": 1 }, { "const": "auto" }] },
            "href": { "type": "string", "format": "uri", "description": "Optional click-through URL." },
            "padding": { "$ref": "#/$defs/Spacing" },
            "alignment": { "enum": ["left", "center", "right"] },
            "borderRadius": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "ButtonBlock": {
      "type": "object",
      "required": ["id", "type", "values"],
      "properties": {
        "id": { "type": "string" },
        "type": { "const": "button" },
        "values": {
          "type": "object",
          "required": ["content", "href", "backgroundColor", "textColor", "borderRadius", "padding", "innerPadding", "fontSize", "fontWeight", "alignment", "fullWidth"],
          "properties": {
            "content": { "type": "string", "description": "HTML string (typically `<p>Label</p>`). The renderer strips the outer <p> so the button label is inline." },
            "href": { "type": "string", "format": "uri" },
            "backgroundColor": { "type": "string" },
            "textColor": { "type": "string" },
            "borderRadius": { "type": "integer", "minimum": 0 },
            "padding": { "$ref": "#/$defs/Spacing" },
            "innerPadding": { "$ref": "#/$defs/Spacing" },
            "fontSize": { "type": "integer", "minimum": 8 },
            "fontWeight": { "type": "string", "examples": ["400", "500", "600", "700"] },
            "alignment": { "enum": ["left", "center", "right"] },
            "fullWidth": { "type": "boolean" }
          }
        }
      }
    },
    "DividerBlock": {
      "type": "object",
      "required": ["id", "type", "values"],
      "properties": {
        "id": { "type": "string" },
        "type": { "const": "divider" },
        "values": {
          "type": "object",
          "required": ["borderColor", "borderWidth", "borderStyle", "padding", "width"],
          "properties": {
            "borderColor": { "type": "string" },
            "borderWidth": { "type": "integer", "minimum": 1 },
            "borderStyle": { "enum": ["solid", "dashed", "dotted"] },
            "padding": { "$ref": "#/$defs/Spacing" },
            "width": { "type": "string", "examples": ["100%", "50%"] }
          }
        }
      }
    },
    "SpacerBlock": {
      "type": "object",
      "required": ["id", "type", "values"],
      "properties": {
        "id": { "type": "string" },
        "type": { "const": "spacer" },
        "values": {
          "type": "object",
          "required": ["height"],
          "properties": { "height": { "type": "integer", "minimum": 1 } }
        }
      }
    },
    "SocialBlock": {
      "type": "object",
      "required": ["id", "type", "values"],
      "properties": {
        "id": { "type": "string" },
        "type": { "const": "social" },
        "values": {
          "type": "object",
          "required": ["icons", "iconSize", "spacing", "alignment", "padding"],
          "properties": {
            "icons": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["type", "href"],
                "properties": {
                  "type": { "enum": ["facebook", "twitter", "instagram", "linkedin", "youtube", "tiktok", "custom"] },
                  "href": { "type": "string", "format": "uri" },
                  "label": { "type": "string" },
                  "iconUrl": { "type": "string", "format": "uri", "description": "Required when type is \"custom\"." }
                }
              }
            },
            "iconSize": { "type": "integer", "minimum": 8 },
            "spacing": { "type": "integer", "minimum": 0 },
            "alignment": { "enum": ["left", "center", "right"] },
            "padding": { "$ref": "#/$defs/Spacing" }
          }
        }
      }
    },
    "HtmlBlock": {
      "type": "object",
      "description": "Escape hatch — raw HTML/MJML passed through to the renderer. Use sparingly; prefer typed blocks.",
      "required": ["id", "type", "values"],
      "properties": {
        "id": { "type": "string" },
        "type": { "const": "html" },
        "values": {
          "type": "object",
          "required": ["content", "padding"],
          "properties": {
            "content": { "type": "string" },
            "padding": { "$ref": "#/$defs/Spacing" }
          }
        }
      }
    },
    "HeroBlock": {
      "type": "object",
      "required": ["id", "type", "values"],
      "properties": {
        "id": { "type": "string" },
        "type": { "const": "hero" },
        "values": {
          "type": "object",
          "required": ["backgroundUrl", "backgroundPosition", "mode", "width", "height", "verticalAlign", "padding", "innerPadding", "backgroundColor", "content"],
          "properties": {
            "backgroundUrl": { "type": "string", "format": "uri" },
            "backgroundPosition": { "enum": ["center center", "top center", "bottom center", "left center", "right center"] },
            "mode": { "enum": ["fixed-height", "fluid-height"] },
            "width": { "type": "integer", "minimum": 1 },
            "height": { "type": "integer", "minimum": 1 },
            "verticalAlign": { "enum": ["top", "middle", "bottom"] },
            "padding": { "$ref": "#/$defs/Spacing" },
            "innerPadding": { "$ref": "#/$defs/Spacing" },
            "backgroundColor": { "type": "string" },
            "content": { "type": "string", "description": "HTML overlay (typically headline + sub-headline + button)." }
          }
        }
      }
    },
    "NavBarBlock": {
      "type": "object",
      "required": ["id", "type", "values"],
      "properties": {
        "id": { "type": "string" },
        "type": { "const": "navbar" },
        "values": {
          "type": "object",
          "required": ["links", "hamburger", "alignment", "padding", "linkColor", "linkFontSize", "linkPadding"],
          "properties": {
            "links": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["href", "text"],
                "properties": {
                  "href": { "type": "string", "format": "uri" },
                  "text": { "type": "string" },
                  "color": { "type": "string" },
                  "fontWeight": { "type": "string" },
                  "textDecoration": { "type": "string" },
                  "padding": { "type": "string" }
                }
              }
            },
            "hamburger": { "enum": ["hamburger", "none"] },
            "alignment": { "enum": ["left", "center", "right"] },
            "padding": { "$ref": "#/$defs/Spacing" },
            "linkColor": { "type": "string" },
            "linkFontSize": { "type": "integer", "minimum": 1 },
            "linkPadding": { "type": "string" }
          }
        }
      }
    }
  }
}
